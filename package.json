{
  "name": "openrefine-vscode",
  "displayName": "OpenRefine for VS Code",
  "description": "Integration with OpenRefine for data cleaning and exploration.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Data Science",
    "Visualization",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "openrefine.editor",
        "displayName": "OpenRefine",
        "selector": [
          {
            "filenamePattern": "*.csv"
          },
          {
            "filenamePattern": "*.tsv"
          },
          {
            "filenamePattern": "*.json"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "openrefine.save",
        "title": "OpenRefine: Save to File"
      }
    ],
    "configuration": {
      "title": "OpenRefine",
      "properties": {
        "openrefine.javaPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Java executable. Leave empty to use system Java."
        },
        "openrefine.installPath": {
          "type": "string",
          "default": "",
          "description": "Path to the OpenRefine executable (refine on Linux/Mac, refine.bat on Windows)."
        },
        "openrefine.server.port": {
          "type": "number",
          "default": 3333,
          "description": "Port for local OpenRefine server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.x",
    "@typescript-eslint/eslint-plugin": "^6.x",
    "@typescript-eslint/parser": "^6.x",
    "eslint": "^8.x",
    "glob": "^10.x",
    "mocha": "^10.x",
    "typescript": "^5.x",
    "@vscode/test-electron": "^2.x"
  }
}
